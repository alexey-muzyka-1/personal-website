---
import Base from '../layouts/Base.astro';
import { SITE } from '../config';
import { agents } from '../data/agents';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const books = (await getCollection('books'))
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 6);
---

<Base>
  <header class="head">
    <img class="portrait" src={`${base}me.jpg`} alt="Лёша Музыка" width="110" height="110" />
    <div class="head-text">
      <h1>Лёша Музыка</h1>
      <p class="hero-tagline">Основатель Viralmaxing. Строю AI-native компании через агентов.</p>
    </div>
  </header>

  <section class="block">
    <p>Главный фокус — <strong>Viralmaxing</strong>. Строю его как AI-native компанию: весь pipeline от идеи до прода держат агенты, а не раздутый штат.</p>
    <p>Автоматизирую весь трек — поддержку, разработку, деплой, мониторинг — через агентов. Задача наглая — собрать тех-компанию, которой можно рулить <strong>одному</strong>.</p>
    <a class="card" href={SITE.viralmaxing}>
      <img class="card-logo" src={`${base}viralmaxing-logo.png`} alt="Viralmaxing" width="52" height="52" />
      <div class="card-body">
        <h3>Viralmaxing</h3>
        <p>Находишь сильные идеи, разбираешь конкурентов и пишешь сценарии в одной системе.</p>
      </div>
      <span class="card-arrow" aria-hidden="true">↗</span>
    </a>
  </section>

  <section class="block">
    <p>Параллельно веду телеграм-канал — редко, но метко. Без потока ради потока.</p>
    <p>Кидаю туда то, что зацепило: разборы статей, интересное из продукта, находки по агентам. Если близко — подписывайся.</p>
    <a class="card" href={SITE.telegram}>
      <span class="card-logo card-logo-tg" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
      </span>
      <div class="card-body">
        <h3>Мой блог</h3>
        <p>Телеграм-канал — редко, но метко.</p>
      </div>
      <span class="card-arrow" aria-hidden="true">↗</span>
    </a>
  </section>

  <section class="block section-major">
    <h2 class="section-h">Агенты <span class="all"><a href={`${base}agents`}>все →</a></span></h2>
    <p>Кроме Viralmaxing, перестраиваю агентами и остальную жизнь — частью делюсь на GitHub.</p>
    <table class="tbl">
      <tbody>
        {agents.map((a, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td class="t nowrap"><a href={a.href}>{a.name}</a></td>
            <td class="w">{a.what}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="block">
    <h2 class="section-h">Книги <span class="all"><a href={`${base}books`}>все →</a></span></h2>
    <p>Мой субъективный топ книг, которые в той или иной мере на меня повлияли. Можете забрать себе, можете нет.</p>
    <p class="subnote">Список пополняется время от времени.</p>
    <table class="tbl">
      <thead><tr><th class="num">#</th><th>Книга</th><th>Автор</th></tr></thead>
      <tbody>
        {books.map((b, i) => (
          <tr>
            <td class="num">{i + 1}</td>
            <td class="t">{b.data.link ? <a href={b.data.link}>{b.data.title} <span class="ext">↗</span></a> : b.data.title}</td>
            <td class="by">{b.data.author}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</Base>
